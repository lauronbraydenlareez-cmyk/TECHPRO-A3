import java.util.Random;
import java.util.Scanner;

public class SeatWorkTask3 {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Random random = new Random();

        System.out.print("How many random numbers do you want to generate? ");
        int count = scanner.nextInt();

        System.out.println("\nRandom numbers using Math.random():");
        for (int i = 0; i < count; i++) {
            // Generate a random double between 0.0 and 1.0
            double randValue = Math.random();
            System.out.printf("%.4f  ", randValue);
        }

        System.out.println("\n\nRandom integers between 0 and 99 using Random class:");
        for (int i = 0; i < count; i++) {
            // Generate random integer from 0 to 99
            int randInt = random.nextInt(100);
            System.out.print(randInt + " ");
        }

        System.out.println("\n\nRandom numbers between 1 and 10:");
        for (int i = 0; i < count; i++) {
            int customRange = random.nextInt(10) + 1; // 1 to 10
            System.out.print(customRange + " ");
        }

        scanner.close();
    }
}
